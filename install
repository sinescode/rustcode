#!/usr/bin/env bash
set -euo pipefail
APP=blazecode

MUTED='\033[0;2m'
RED='\033[0;31m'
ORANGE='\033[38;5;214m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Defaults
REPO="${REPO:-sinescode/blazecode}"
INSTALL_DIR="${INSTALL_DIR:-}"
requested_version=""
no_modify_path=false
binary_path=""
skip_checksum=false

usage() {
    cat <<EOF
BlazeCode Installer

Usage: install [options]

Options:
    -h, --help              Display this help message
    -v, --version <version> Install a specific version (e.g., 0.1.0)
    -b, --binary <path>     Install from a local binary instead of downloading
        --no-modify-path    Don't modify shell config files (.zshrc, .bashrc, etc.)
        --dir <path>        Install to a specific directory (default: ~/.local/bin or /usr/local/bin)
        --skip-checksum     Skip SHA256 checksum verification

Examples:
    curl -fsSL https://raw.githubusercontent.com/sinescode/blazecode/main/install | bash
    curl -fsSL https://raw.githubusercontent.com/sinescode/blazecode/main/install | bash -s -- --version 0.1.0
    ./install --binary /path/to/blazecode
    ./install --dir ~/bin
EOF
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        -v|--version)
            if [[ -n "${2:-}" ]]; then
                requested_version="$2"
                shift 2
            else
                echo -e "${RED}Error: --version requires a version argument${NC}"
                exit 1
            fi
            ;;
        -b|--binary)
            if [[ -n "${2:-}" ]]; then
                binary_path="$2"
                shift 2
            else
                echo -e "${RED}Error: --binary requires a path argument${NC}"
                exit 1
            fi
            ;;
        --no-modify-path)
            no_modify_path=true
            shift
            ;;
        --dir)
            if [[ -n "${2:-}" ]]; then
                INSTALL_DIR="$2"
                shift 2
            else
                echo -e "${RED}Error: --dir requires a path argument${NC}"
                exit 1
            fi
            ;;
        --skip-checksum)
            skip_checksum=true
            shift
            ;;
        *)
            echo -e "${ORANGE}Warning: Unknown option '$1'${NC}" >&2
            shift
            ;;
    esac
done

# ---------------------------------------------------------------------------
# Platform detection
# ---------------------------------------------------------------------------
detect_platform() {
    raw_os=$(uname -s)
    os=$(echo "$raw_os" | tr '[:upper:]' '[:lower:]')
    case "$raw_os" in
      Darwin*) os="apple-darwin" ;;
      Linux*)  os="unknown-linux-gnu" ;;
      MINGW*|MSYS*|CYGWIN*) os="pc-windows-msvc" ;;
    esac

    arch=$(uname -m)
    if [[ "$arch" == "aarch64" ]] || [[ "$arch" == "arm64" ]]; then
      arch="aarch64"
    elif [[ "$arch" == "x86_64" ]] || [[ "$arch" == "amd64" ]]; then
      arch="x86_64"
    fi

    # On macOS x86_64, check if running under Rosetta -> use arm64 binary
    if [[ "$raw_os" == "Darwin" ]] && [[ "$arch" == "x86_64" ]]; then
      rosetta_flag=$(sysctl -n sysctl.proc_translated 2>/dev/null || echo 0)
      if [[ "$rosetta_flag" == "1" ]]; then
        arch="aarch64"
      fi
    fi

    # Detect musl on Linux
    is_musl=false
    if [[ "$os" == "unknown-linux-gnu" ]]; then
      if [[ -f /etc/alpine-release ]]; then
        is_musl=true
      fi
      if command -v ldd >/dev/null 2>&1; then
        if ldd --version 2>&1 | grep -qi musl; then
          is_musl=true
        fi
      fi
    fi

    if [[ "$is_musl" == "true" ]]; then
      os="unknown-linux-musl"
    fi

    TARGET="${arch}-${os}"
    echo "$TARGET"
}

# ---------------------------------------------------------------------------
# Determine archive extension for a target triple
# ---------------------------------------------------------------------------
archive_ext_for_target() {
    case "$1" in
        *-pc-windows-*) echo "zip" ;;
        *) echo "tar.gz" ;;
    esac
}

# ---------------------------------------------------------------------------
# Download and verify
# ---------------------------------------------------------------------------
download_release() {
    local target="$1"
    local version="$2"
    local ext="$3"
    local filename="${APP}-${target}-v${version}.${ext}"
    local url="https://github.com/${REPO}/releases/download/v${version}/${filename}"
    local tmp_dir="${TMPDIR:-/tmp}/${APP}_install_$$"
    mkdir -p "$tmp_dir"

    echo -e "${MUTED}Downloading ${APP} v${version} (${target})...${NC}"

    # Download with progress
    curl -# -L -o "${tmp_dir}/${filename}" "$url" 2>&1

    if [[ ! -f "${tmp_dir}/${filename}" ]]; then
        echo -e "${RED}Error: Failed to download ${url}${NC}"
        exit 1
    fi

    # Download SHA256
    local sha_url="https://github.com/${REPO}/releases/download/v${version}/${filename}.sha256"
    local sha_file="${tmp_dir}/${filename}.sha256"
    if curl -sL -o "$sha_file" "$sha_url"; then
        echo -e "${MUTED}Verifying SHA256 checksum...${NC}"
        (cd "$tmp_dir" && sha256sum -c "${filename}.sha256" 2>/dev/null) || \
        (cd "$tmp_dir" && shasum -a 256 -c "${filename}.sha256" 2>/dev/null) || {
            if [[ "$skip_checksum" != "true" ]]; then
                echo -e "${RED}Error: SHA256 checksum verification failed${NC}"
                exit 1
            else
                echo -e "${ORANGE}Warning: SHA256 checksum verification skipped${NC}"
            fi
        }
    else
        echo -e "${ORANGE}Warning: No SHA256 checksum found, skipping verification${NC}"
    fi

    echo "$tmp_dir/$filename"
}

# ---------------------------------------------------------------------------
# Install binary
# ---------------------------------------------------------------------------
install_binary() {
    local archive_path="$1"
    local target="$2"
    local ext="$3"
    local tmp_dir
    tmp_dir=$(dirname "$archive_path")

    echo -e "${MUTED}Extracting...${NC}"

    if [[ "$ext" == "tar.gz" ]]; then
        tar -xzf "$archive_path" -C "$tmp_dir"
    else
        unzip -q "$archive_path" -d "$tmp_dir"
    fi

    # Find the binary within the extracted directory
    local extracted
    extracted=$(find "$tmp_dir" -maxdepth 3 -type f \( -name "${APP}" -o -name "${APP}.exe" \) 2>/dev/null | head -1)

    if [[ -z "$extracted" ]]; then
        echo -e "${RED}Error: Could not find ${APP} binary in extracted archive${NC}"
        ls -la "$tmp_dir" >&2
        exit 1
    fi

    mkdir -p "$INSTALL_DIR"
    cp "$extracted" "${INSTALL_DIR}/${APP}"
    chmod 755 "${INSTALL_DIR}/${APP}"
    rm -rf "$tmp_dir"

    echo -e "${GREEN}Installed ${APP} to ${INSTALL_DIR}/${APP}${NC}"
}

# ---------------------------------------------------------------------------
# Add to PATH
# ---------------------------------------------------------------------------
add_to_path() {
    local config_file=$1
    local command=$2

    if grep -Fxq "$command" "$config_file" 2>/dev/null; then
        echo -e "${MUTED}Command already exists in ${config_file}, skipping.${NC}"
    elif [[ -w $config_file ]]; then
        echo -e "\n# ${APP}" >> "$config_file"
        echo "$command" >> "$config_file"
        echo -e "${MUTED}Added ${APP} to \$PATH in ${NC}${config_file}"
    else
        echo -e "${ORANGE}Manually add the directory to ${config_file}:${NC}"
        echo -e "  ${command}"
    fi
}

# ===========================================================================
# Main
# ===========================================================================

# If --binary is provided, skip all download/detection logic
if [[ -n "$binary_path" ]]; then
    if [[ ! -f "$binary_path" ]]; then
        echo -e "${RED}Error: Binary not found at ${binary_path}${NC}"
        exit 1
    fi

    # Determine install directory
    if [[ -z "$INSTALL_DIR" ]]; then
        if [[ -w /usr/local/bin ]]; then
            INSTALL_DIR=/usr/local/bin
        else
            INSTALL_DIR="${HOME}/.local/bin"
        fi
    fi
    mkdir -p "$INSTALL_DIR"

    cp "$binary_path" "${INSTALL_DIR}/${APP}"
    chmod 755 "${INSTALL_DIR}/${APP}"
    echo -e "${GREEN}Installed ${APP} to ${INSTALL_DIR}/${APP}${NC}"
else
    # Detect platform
    TARGET=$(detect_platform)
    echo -e "${MUTED}Detected platform: ${NC}${TARGET}"

    # Validate platform
    case "$TARGET" in
        x86_64-unknown-linux-gnu|x86_64-unknown-linux-musl|aarch64-unknown-linux-gnu|x86_64-apple-darwin|aarch64-apple-darwin|x86_64-pc-windows-msvc)
            ;;
        *)
            echo -e "${RED}Unsupported platform: ${TARGET}${NC}"
            echo -e "${MUTED}Supported: x86_64/aarch64 Linux, x86_64/aarch64 macOS, x86_64 Windows${NC}"
            exit 1
            ;;
    esac

    # Determine install directory
    if [[ -z "$INSTALL_DIR" ]]; then
        if [[ -w /usr/local/bin ]]; then
            INSTALL_DIR=/usr/local/bin
        else
            INSTALL_DIR="${HOME}/.local/bin"
        fi
    fi
    mkdir -p "$INSTALL_DIR"

    # Determine version
    if [[ -z "$requested_version" ]]; then
        echo -e "${MUTED}Fetching latest release...${NC}"
        latest=$(curl -sL "https://api.github.com/repos/${REPO}/releases/latest" 2>/dev/null || echo "")
        requested_version=$(echo "$latest" | sed -n 's/.*"tag_name": *"v\([^"]*\)".*/\1/p')

        if [[ -z "$requested_version" ]]; then
            echo -e "${RED}Error: Failed to fetch latest version from GitHub${NC}"
            echo -e "${MUTED}Try specifying a version with --version${NC}"
            exit 1
        fi
        echo -e "${MUTED}Latest version: ${NC}v${requested_version}"
    else
        # Strip leading 'v' if present
        requested_version="${requested_version#v}"
        echo -e "${MUTED}Requested version: ${NC}v${requested_version}"
    fi

    # Check if already installed with same version
    if command -v "${APP}" >/dev/null 2>&1; then
        installed_version=$("${APP}" --version 2>/dev/null || echo "")
        if [[ "$installed_version" == "$requested_version" ]]; then
            echo -e "${GREEN}${APP} v${requested_version} is already installed${NC}"
            exit 0
        fi
    fi

    # Check for required tools
    if ! command -v curl >/dev/null 2>&1; then
        echo -e "${RED}Error: 'curl' is required but not installed.${NC}"
        exit 1
    fi
    if ! command -v sha256sum >/dev/null 2>&1 && ! command -v shasum >/dev/null 2>&1; then
        echo -e "${RED}Error: 'sha256sum' or 'shasum' is required but not installed.${NC}"
        exit 1
    fi

    ARCHIVE_EXT=$(archive_ext_for_target "$TARGET")

    # Verify release exists
    echo -e "${MUTED}Checking release v${requested_version}...${NC}"
    http_status=$(curl -sI -o /dev/null -w "%{http_code}" \
        "https://github.com/${REPO}/releases/tag/v${requested_version}" 2>/dev/null || echo "000")
    if [[ "$http_status" == "404" ]] || [[ "$http_status" == "000" ]]; then
        echo -e "${RED}Error: Release v${requested_version} not found${NC}"
        echo -e "${MUTED}Available releases: https://github.com/${REPO}/releases${NC}"
        exit 1
    fi

    # Download
    archive_path=$(download_release "$TARGET" "$requested_version" "$ARCHIVE_EXT")

    # Install
    install_binary "$archive_path" "$TARGET" "$ARCHIVE_EXT"
fi

# ---------------------------------------------------------------------------
# PATH modification
# ---------------------------------------------------------------------------
if [[ "$no_modify_path" != "true" ]]; then
    if [[ ":$PATH:" != *":$INSTALL_DIR:"* ]]; then
        current_shell=$(basename "${SHELL:-bash}")

        case $current_shell in
            fish)
                config_files="$HOME/.config/fish/config.fish"
                cmd="fish_add_path ${INSTALL_DIR}"
                ;;
            zsh)
                config_files="${ZDOTDIR:-$HOME}/.zshrc"
                cmd="export PATH=${INSTALL_DIR}:\$PATH"
                ;;
            bash)
                config_files="$HOME/.bashrc"
                cmd="export PATH=${INSTALL_DIR}:\$PATH"
                ;;
            ash|sh)
                config_files="$HOME/.profile"
                cmd="export PATH=${INSTALL_DIR}:\$PATH"
                ;;
            *)
                config_files="$HOME/.bashrc"
                cmd="export PATH=${INSTALL_DIR}:\$PATH"
                ;;
        esac

        if [[ -f $config_files ]]; then
            add_to_path "$config_files" "$cmd"
        else
            echo -e "${ORANGE}No shell config file found. Add to PATH manually:${NC}"
            echo -e "  ${cmd}"
        fi
    fi
fi

# ---------------------------------------------------------------------------
# Success message
# ---------------------------------------------------------------------------
echo ""
echo -e "${GREEN}  BlazeCode ${MUTED}v${requested_version:-local} installed successfully!${NC}"
echo ""
echo -e "${MUTED}  Get started: ${NC}${APP} --help"
echo ""
echo -e "${MUTED}  More info: ${NC}https://github.com/${REPO}"
echo ""
